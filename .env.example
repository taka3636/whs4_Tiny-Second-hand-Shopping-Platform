# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.  (cp .env.example .env)
# .env 는 .gitignore 에 등록되어 있어 GitHub 에 올라가지 않습니다.

# ── 구글 reCAPTCHA v2 (체크박스) ─────────────────────────────
# https://www.google.com/recaptcha/admin 에서 사이트를 등록하고 발급받으세요.
# reCAPTCHA v2 "안 로봇입니다" 체크박스 유형 선택, 도메인에 localhost 추가.
# 두 값이 모두 채워지면 회원가입에 실제 reCAPTCHA 가 적용됩니다.
# (비워두면 키 없이도 동작하도록 간단한 산술 보안문자로 자동 대체)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ── 서버 설정(선택) ────────────────────────────────────────
# PORT=3000
# SESSION_SECRET=여기에-길고-무작위한-값
# ADMIN_USER=admin
# ADMIN_PASS=Admin!2345
# PRODUCT_THRESHOLD=3
# USER_THRESHOLD=3
