<% var title = '상품 — Blue Market' %>
<%- include('partials/header') %>

<div class="section-title">
  <h1 style="margin:0">상품</h1>
  <% if (currentUser) { %><a class="btn sm" href="/products/new">+ 판매하기</a><% } %>
</div>

<form method="get" action="/products" style="margin-bottom:22px">
  <div class="row">
    <input type="search" name="q" placeholder="상품명으로 검색" value="<%= q %>">
    <button class="btn" type="submit" style="flex:0 0 auto">검색</button>
  </div>
</form>

<% if (q) { %><p class="muted small">"<%= q %>" 검색 결과 <%= products.length %>건</p><% } %>

<% if (products.length === 0) { %>
  <div class="card center muted">표시할 상품이 없습니다.</div>
<% } else { %>
  <div class="grid">
    <% products.forEach(function(p){ %>
      <a class="product" href="/products/<%= p.id %>">
        <% if (p.image) { %>
          <div class="thumb" style="padding:0;overflow:hidden"><img src="/uploads/<%= p.image %>" alt="<%= p.name %>" style="width:100%;height:100%;object-fit:cover"></div>
        <% } else { %>
          <div class="thumb">사진</div>
        <% } %>
        <div class="pname"><%= p.name %></div>
        <div class="price"><%= p.price.toLocaleString() %>원</div>
      </a>
    <% }); %>
  </div>
<% } %>

<p class="muted small center" style="margin-top:30px">💬 전체 채팅은 <a href="/">홈 화면</a> 하단에서 이용할 수 있어요.</p>

<%- include('partials/footer') %>
