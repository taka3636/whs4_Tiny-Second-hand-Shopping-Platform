<% var title = '쪽지함 — Blue Market' %>
<%- include('partials/header') %>
<h1>쪽지함</h1>
<p class="muted small">1:1 채팅한 상대 목록입니다. 상대를 눌러 대화를 이어가세요.</p>
<div class="card">
  <% if (convos.length === 0) { %>
    <p class="muted center">아직 주고받은 1:1 채팅이 없습니다. 상품 상세나 사용자 프로필에서 1:1 채팅을 시작할 수 있어요.</p>
  <% } else { %>
    <table>
      <thead><tr><th>상대</th><th>최근 메시지</th><th>시간</th><th></th></tr></thead>
      <tbody>
        <% convos.forEach(function(c){ %>
          <tr>
            <td><a href="/users/<%= c.other.id %>#dm"><%= c.other.display_name %></a> <span class="muted small">@<%= c.other.username %></span></td>
            <td class="small"><%= c.last ? c.last.content : '' %></td>
            <td class="muted small"><%= c.last ? c.last.created_at : '' %></td>
            <td style="text-align:right"><a class="btn sm ghost" href="/users/<%= c.other.id %>#dm">대화</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('partials/footer') %>
