<% var title = '지갑 — Blue Market' %>
<%- include('partials/header') %>
<div class="narrow" style="margin:0 auto">
  <h1 class="center">지갑</h1>
  <% if (error) { %><div class="alert err"><%= error %></div><% } %>
  <% if (notice) { %><div class="alert ok"><%= notice %></div><% } %>

  <div class="card center">
    <p class="muted small" style="margin:0">현재 잔액</p>
    <div class="balance"><%= me.balance.toLocaleString() %>원</div>
  </div>

  <div class="card">
    <h3>충전</h3>
    <form method="post" action="/wallet/charge">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row">
        <input type="number" name="amount" min="1" step="1" placeholder="충전 금액" required>
        <button class="btn" type="submit" style="flex:0 0 auto">충전</button>
      </div>
    </form>
  </div>

  <div class="card">
    <h3>송금</h3>
    <form method="post" action="/wallet/send">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>받는 사람 아이디</label>
      <input type="text" name="to_username" value="<%= prefill.to %>" required>
      <label>금액</label>
      <input type="number" name="amount" min="1" step="1" value="<%= prefill.amount %>" required>
      <label>메모 <span class="muted small">(선택)</span></label>
      <input type="text" name="memo" maxlength="100">
      <div style="margin-top:16px"><button class="btn block" type="submit">송금하기</button></div>
    </form>
  </div>

  <div class="card">
    <h3>거래 내역</h3>
    <% if (history.length === 0) { %>
      <p class="muted center small">거래 내역이 없습니다.</p>
    <% } else { %>
      <table>
        <thead><tr><th>구분</th><th>상대</th><th>금액</th><th>일시</th></tr></thead>
        <tbody>
          <% history.forEach(function(t){ var out = t.sender_id === me.id; %>
            <tr>
              <td><% if (out) { %><span class="tag red">출금</span><% } else { %><span class="tag green">입금</span><% } %></td>
              <td><%= out ? t.receiver_name : t.sender_name %></td>
              <td><%= out ? '-' : '+' %><%= t.amount.toLocaleString() %>원</td>
              <td class="muted small"><%= t.created_at %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
